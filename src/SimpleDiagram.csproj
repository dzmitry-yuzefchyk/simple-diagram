<Project Sdk="Godot.NET.Sdk/4.6.1">
  <PropertyGroup>
    <EnableDynamicLoading>true</EnableDynamicLoading>
    <RootNamespace>SimpleDiagram</RootNamespace>
    <TargetFramework>net8.0</TargetFramework>
    <LangVersion>12</LangVersion>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Antlr4.Runtime.Standard" Version="4.13.1" />
    <PackageReference Include="Antlr4BuildTasks" Version="12.14.0" />
  </ItemGroup>

  <ItemGroup>
    <Antlr4 Include="Parser\Mermaid\Grammar\*.g4">
      <Package>SimpleDiagram.Parser.Mermaid.Grammar</Package>
      <Listener>true</Listener>
      <Visitor>true</Visitor>
    </Antlr4>
  </ItemGroup>

  <ItemGroup>
    <Folder Include="Parser\SimpleDiagramProjectFile\" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="Parser\Mermaid\Test.mermaid" />
  </ItemGroup>
</Project>
